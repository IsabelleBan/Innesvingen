    "rich_text_TbaeMG": {
      "type": "rich-text",
      "blocks": {
        "heading_yTLwQJ": {
          "type": "heading",
          "settings": {
            "heading": "Lysegårdens Golfklubb",
            "highlight_style": "none",
            "highlight_font_style": "italic",
