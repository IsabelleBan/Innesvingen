    "rich_text_ekNXkE": {
      "type": "rich-text",
      "blocks": {
        "heading_h9UCRe": {
          "type": "heading",
          "settings": {
            "heading": "Avslutning med finalspel",
            "highlight_style": "none",
            "highlight_font_style": "italic",
            "highlight_style_color": "",
            "highlight_text_color": "",
            "heading_size": "h1"
          }
