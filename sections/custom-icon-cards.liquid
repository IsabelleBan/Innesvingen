<div class="section-icon-cards has-fullwidth has-side-margin has-align-center color-{{ section.settings.color_scheme }}">
  <div class="section-icon-cards-container section-container">
    <div class="section-icon-cards-content">
      {%- for block in section.blocks -%}
        <div class="section-icon-cards-card">
          {%- if block.settings.icon_svg != blank -%}
            <div class="section-icon-cards-card__icon">
              {{ block.settings.icon_svg }}
            </div>
          {%- endif -%}
          
          {%- if block.settings.heading != blank -%}
            <h3 class="section-icon-cards-card__heading heading-size-x-small">
              {{ block.settings.heading }}
            </h3>
          {%- endif -%}
          
          {%- if block.settings.description != blank -%}
            <div class="section-icon-cards-card__description">
              <p>{{ block.settings.description }}</p>
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Icon Cards",
  "settings": [
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "options": [
        {
          "value": "scheme-1",
          "label": "Scheme 1"
        },
        {
          "value": "scheme-2",
          "label": "Scheme 2"
        },
        {
          "value": "scheme-11",
          "label": "Scheme 11"
        }
      ],
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Icon Card",
      "settings": [
        {
          "type": "html",
          "id": "icon_svg",
          "label": "SVG Icon",
          "info": "Paste SVG code here"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Heading"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "Description text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Icon Cards",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "heading": "Leverans",
            "description": "2 – 5 arbetsdagar"
          }
        },
        {
          "type": "card",
          "settings": {
            "heading": "Öppet köp",
            "description": "14 dagar"
          }
        },
        {
          "type": "card",
          "settings": {
            "heading": "Kundklubb",
            "description": "Exklusiva erbjudanden"
          }
        }
      ]
    }
  ]
}
{% endschema %}