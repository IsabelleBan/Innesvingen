{% doc %}
  @prompt
    add a section with text and link, add a button link, i diont see it
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-text-link-block-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
    text-align: {{ block.settings.text_alignment }};
  }

  @media screen and (min-width: 750px) {
    .ai-text-link-block-{{ ai_gen_id }} {
      width: {{ block.settings.desktop_width_percent }}%;
      margin-left: {% if block.settings.text_alignment == 'center' %}auto{% elsif block.settings.text_alignment == 'right' %}auto{% else %}0{% endif %};
      margin-right: {% if block.settings.text_alignment == 'center' %}auto{% elsif block.settings.text_alignment == 'right' %}0{% else %}auto{% endif %};
    }
  }

  .ai-text-link-block__heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 {{ block.settings.spacing_below_heading }}px;
  }

  .ai-text-link-block__text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.6;
    margin: 0 0 {{ block.settings.spacing_below_text }}px;
  }

  .ai-text-link-block__link-{{ ai_gen_id }} {
    display: inline-block;
    padding: 12px 24px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    font-weight: 700;
    transition: all 0.3s ease;
  }

  .ai-text-link-block__link-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
  }
{% endstyle %}

<div class="ai-text-link-block-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.heading != blank %}
    <h2 class="ai-text-link-block__heading-{{ ai_gen_id }}">
      {{ block.settings.heading }}
    </h2>
  {% endif %}

  {% if block.settings.text != blank %}
    <div class="ai-text-link-block__text-{{ ai_gen_id }}">
      {{ block.settings.text }}
    </div>
  {% endif %}

  {% if block.settings.link_text != blank and block.settings.link_url != blank %}
    <a href="{{ block.settings.link_url }}" class="ai-text-link-block__link-{{ ai_gen_id }}">
      {{ block.settings.link_text }}
    </a>
  {% endif %}
</div>

{% schema %}
{
  "name": "Text med länk",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Innehåll"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Rubrik",
      "default": "Välkommen till vår butik"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Upptäck vårt sortiment av premiumutrustning för golf. Vi erbjuder allt från drivers till tillbehör."
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "Länktext",
      "default": "Handla nu"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Länk-URL"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Textjustering",
      "options": [
        {
          "value": "left",
          "label": "Vänster"
        },
        {
          "value": "center",
          "label": "Centrerad"
        },
        {
          "value": "right",
          "label": "Höger"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Bredd på desktop",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding ovan",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding under",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Padding sidled",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Rubrik"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Rubrikstorlek",
      "min": 16,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Rubrikfärg",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "spacing_below_heading",
      "label": "Avstånd under rubrik",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 15
    },
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Textstorlek",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Textfärg",
      "default": "#666666"
    },
    {
      "type": "range",
      "id": "spacing_below_text",
      "label": "Avstånd under text",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 25
    },
    {
      "type": "header",
      "content": "Knapp"
    },
    {
      "type": "range",
      "id": "button_text_size",
      "label": "Knapptextstorlek",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Knappbakgrund",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Knapptextfärg",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_background",
      "label": "Knappbakgrund vid hover",
      "default": "#c4301c"
    },
    {
      "type": "color",
      "id": "button_hover_text_color",
      "label": "Knapptextfärg vid hover",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Knappens hörnradie",
      "min": 0,
      "max": 50,
      "step": 2,
      "unit": "px",
      "default": 30
    },
    {
      "type": "header",
      "content": "Färger"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Bakgrundsfärg",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Text med länk"
    }
  ]
}
{% endschema %}