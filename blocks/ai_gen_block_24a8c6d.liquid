{% doc %}
  @prompt
    add brand filter as buttons
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-brand-filter-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-brand-filter__container-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ai-brand-filter__heading-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.text_color }};
  }

  .ai-brand-filter__buttons-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: {{ block.settings.button_gap }}px;
  }

  .ai-brand-filter__button-{{ ai_gen_id }} {
    padding: 12px 24px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    border: 2px solid {{ block.settings.button_border_color }};
    border-radius: {% if block.settings.button_corner_radius == 'square' %}0{% elsif block.settings.button_corner_radius == 'slightly' %}8px{% elsif block.settings.button_corner_radius == 'soft-pill' %}16px{% else %}100px{% endif %};
    cursor: pointer;
    transition: all 0.3s ease;
    font-weight: 700;
    text-decoration: none;
    display: inline-block;
  }

  .ai-brand-filter__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  .ai-brand-filter__button-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.button_active_bg_color }};
    color: {{ block.settings.button_active_text_color }};
    border-color: {{ block.settings.button_active_border_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-brand-filter__buttons-{{ ai_gen_id }} {
      gap: {{ block.settings.button_gap_mobile }}px;
    }

    .ai-brand-filter__button-{{ ai_gen_id }} {
      padding: 10px 20px;
      font-size: 14px;
    }
  }
{% endstyle %}

<brand-filter-{{ ai_gen_id }}
  class="ai-brand-filter-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-brand-filter__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h3 class="ai-brand-filter__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h3>
    {% endif %}

    <div class="ai-brand-filter__buttons-{{ ai_gen_id }}">
      {% if block.settings.show_all_button %}
        <a
          href="{{ collection.url }}"
          class="ai-brand-filter__button-{{ ai_gen_id }} {% unless current_tags %}active{% endunless %}"
          data-filter="all"
        >
          {{ block.settings.all_button_text }}
        </a>
      {% endif %}

      {% assign brand_tags = '' %}
      {% if block.settings.brand_filter_type == 'vendor' %}
        {% for product in collection.products %}
          {% assign vendor = product.vendor %}
          {% unless brand_tags contains vendor %}
            {% if brand_tags == '' %}
              {% assign brand_tags = vendor %}
            {% else %}
              {% assign brand_tags = brand_tags | append: ',' | append: vendor %}
            {% endif %}
          {% endunless %}
        {% endfor %}
        {% assign brand_array = brand_tags | split: ',' | sort %}
        {% for brand in brand_array %}
          {% if brand != blank %}
            <a
              href="{{ collection.url }}?filter.p.vendor={{ brand | url_encode }}"
              class="ai-brand-filter__button-{{ ai_gen_id }}"
              data-filter="{{ brand | handleize }}"
            >
              {{ brand }}
            </a>
          {% endif %}
        {% endfor %}
      {% else %}
        {% for tag in collection.all_tags %}
          {% if tag contains block.settings.brand_tag_prefix %}
            {% assign brand_name = tag | remove: block.settings.brand_tag_prefix %}
            <a
              href="{{ collection.url }}/{{ tag | handleize }}"
              class="ai-brand-filter__button-{{ ai_gen_id }} {% if current_tags contains tag %}active{% endif %}"
              data-filter="{{ tag | handleize }}"
            >
              {{ brand_name }}
            </a>
          {% endif %}
        {% endfor %}
      {% endif %}
    </div>
  </div>
</brand-filter-{{ ai_gen_id }}>

<script>
  (function() {
    class BrandFilter{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.buttons = this.querySelectorAll('.ai-brand-filter__button-{{ ai_gen_id }}');
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.buttons.forEach((button) => {
          button.addEventListener('click', (e) => {
            this.buttons.forEach((btn) => btn.classList.remove('active'));
            button.classList.add('active');
          });
        });
      }
    }

    customElements.define('brand-filter-{{ ai_gen_id }}', BrandFilter{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Brand filter",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Filter by brand"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 14,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "select",
      "id": "brand_filter_type",
      "label": "Filter type",
      "options": [
        {
          "value": "vendor",
          "label": "Product vendor"
        },
        {
          "value": "tags",
          "label": "Product tags"
        }
      ],
      "default": "vendor"
    },
    {
      "type": "text",
      "id": "brand_tag_prefix",
      "label": "Tag prefix",
      "default": "Brand:",
      "info": "Only tags starting with this prefix will be shown (e.g., 'Brand:Nike')"
    },
    {
      "type": "checkbox",
      "id": "show_all_button",
      "label": "Show 'All' button",
      "default": true
    },
    {
      "type": "text",
      "id": "all_button_text",
      "label": "All button text",
      "default": "All brands"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Button style"
    },
    {
      "type": "select",
      "id": "button_corner_radius",
      "label": "Corner radius",
      "options": [
        {
          "value": "square",
          "label": "Square"
        },
        {
          "value": "slightly",
          "label": "Slightly rounded"
        },
        {
          "value": "soft-pill",
          "label": "Soft pill"
        },
        {
          "value": "round",
          "label": "Round"
        }
      ],
      "default": "round"
    },
    {
      "type": "range",
      "id": "button_gap",
      "label": "Button gap",
      "min": 4,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "button_gap_mobile",
      "label": "Button gap (mobile)",
      "min": 4,
      "max": 16,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Button colors"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Heading color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Background",
      "default": "#ededed"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Text",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_border_color",
      "label": "Border",
      "default": "#ededed"
    },
    {
      "type": "header",
      "content": "Button hover colors"
    },
    {
      "type": "color",
      "id": "button_hover_bg_color",
      "label": "Background",
      "default": "#1d349a"
    },
    {
      "type": "color",
      "id": "button_hover_text_color",
      "label": "Text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_border_color",
      "label": "Border",
      "default": "#1d349a"
    },
    {
      "type": "header",
      "content": "Button active colors"
    },
    {
      "type": "color",
      "id": "button_active_bg_color",
      "label": "Background",
      "default": "#1d349a"
    },
    {
      "type": "color",
      "id": "button_active_text_color",
      "label": "Text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_active_border_color",
      "label": "Border",
      "default": "#1d349a"
    }
  ],
  "presets": [
    {
      "name": "Brand filter"
    }
  ]
}
{% endschema %}
