</split-grid-{{ ai_gen_id }}>

<script>
  (function() {
    class SplitGrid{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.videos = this.querySelectorAll('.ai-split-grid__background-video-{{ ai_gen_id }}');
        this.setupVideos();
      }

      setupVideos() {
        this.videos.forEach((video) => {
          video.addEventListener('loadedmetadata', () => {
            video.play().catch(() => {});
          });
        });
      }
    }

    customElements.define('split-grid-{{ ai_gen_id }}', SplitGrid{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Split grid boxes",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "grid_split",
      "label": "Grid split ratio",
      "options": [
        { "value": "50-50", "label": "50% - 50%" },
        { "value": "60-40", "label": "60% - 40%" },
        { "value": "70-30", "label": "70% - 30%" },
        { "value": "40-60", "label": "40% - 60%" },
        { "value": "30-70", "label": "30% - 70%" }
      ],
      "default": "50-50"
    },
    {
      "type": "range",
      "id": "box_height",
      "label": "Box height (desktop)",
      "min": 300,
      "max": 800,
      "step": 50,
      "unit": "px",
      "default": 500
    },
    {
      "type": "range",
      "id": "box_height_mobile",
      "label": "Box height (mobile)",
      "min": 200,
      "max": 600,
      "step": 50,
      "unit": "px",
      "default": 400
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between boxes (desktop)",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "gap_mobile",
      "label": "Gap between boxes (mobile)",
      "min": 0,
      "max": 30,
      "step": 5,
      "unit": "px",
      "default": 15
    },
