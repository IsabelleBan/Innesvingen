{% doc %}
  @prompt
    a grid with 3 different boxes 1 with 50% width and the other 2 stacjd on top. with bith video and image background posibillity to several button links, overlay on bakground image and video , make it possible to select uploaded video background, make the video fit in the boxes , overlay syns inte på boxarna, make it possible to adjust the split of 50-50 or 60-40 ocr 70-30 in the with of the boxes and overlay opacity don't show, overlay opcity on the different boxes dont work
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-split-grid-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-split-grid__container-{{ ai_gen_id }} {
    display: grid;
    {% if block.settings.grid_split == '50-50' %}
      grid-template-columns: 1fr 1fr;
    {% elsif block.settings.grid_split == '60-40' %}
      grid-template-columns: 1.5fr 1fr;
    {% elsif block.settings.grid_split == '70-30' %}
      grid-template-columns: 2.33fr 1fr;
    {% elsif block.settings.grid_split == '40-60' %}
      grid-template-columns: 1fr 1.5fr;
    {% elsif block.settings.grid_split == '30-70' %}
      grid-template-columns: 1fr 2.33fr;
    {% endif %}
    gap: {{ block.settings.gap }}px;
    width: 100%;
  }

  .ai-split-grid__logo-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    right: 20px;
    z-index: 4;
    width: 350px;
    height: auto;
  }

  .ai-split-grid__box-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
    min-height: {{ block.settings.box_height }}px;
    display: flex;
    flex-direction: column;
    justify-content: {{ block.settings.content_vertical_alignment }};
    align-items: {{ block.settings.content_horizontal_alignment }};
    padding: {{ block.settings.content_padding }}px;
  }

  .ai-split-grid__box--large-{{ ai_gen_id }} {
    grid-row: span 2;
  }

  .ai-split-grid__background-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    overflow: hidden;
  }

  .ai-split-grid__background-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-split-grid__background-video-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    min-width: 100%;
    min-height: 100%;
    width: auto;
    height: auto;
    object-fit: cover;
  }

  .ai-split-grid__background-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-split-grid__background-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
    opacity: 0.3;
  }

  .ai-split-grid__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 2;
    pointer-events: none;
    display: block !important;
  }

  .ai-split-grid__content-{{ ai_gen_id }} {
    position: relative;
    z-index: 3;
    text-align: {{ block.settings.text_alignment }};
    width: 100%;
    max-width: {{ block.settings.content_max_width }}px;
  }

  .ai-split-grid__heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 {{ block.settings.heading_spacing }}px 0;
    font-weight: 700;
  }

  .ai-split-grid__text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    margin: 0 0 {{ block.settings.text_spacing }}px 0;
    line-height: 1.5;
  }

  .ai-split-grid__buttons-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.button_gap }}px;
    flex-wrap: wrap;
  }

  {% if block.settings.text_alignment == 'center' %}
    .ai-split-grid__buttons-{{ ai_gen_id }} {
      justify-content: center;
    }
  {% elsif block.settings.text_alignment == 'right' %}
    .ai-split-grid__buttons-{{ ai_gen_id }} {
      justify-content: flex-end;
    }
  {% else %}
    .ai-split-grid__buttons-{{ ai_gen_id }} {
      justify-content: flex-start;
    }
  {% endif %}

  .ai-split-grid__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-weight: 600;
    transition: all 0.3s ease;
    border: 2px solid {{ block.settings.button_border_color }};
  }

  .ai-split-grid__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  .ai-split-grid__button--secondary-{{ ai_gen_id }} {
    background-color: {{ block.settings.button_secondary_background }};
    color: {{ block.settings.button_secondary_text_color }};
    border-color: {{ block.settings.button_secondary_border_color }};
  }

  .ai-split-grid__button--secondary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_secondary_hover_background }};
    color: {{ block.settings.button_secondary_hover_text_color }};
    border-color: {{ block.settings.button_secondary_hover_border_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-split-grid__container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.gap_mobile }}px;
    }

    .ai-split-grid__box--large-{{ ai_gen_id }} {
      grid-row: span 1;
    }

    .ai-split-grid__box-{{ ai_gen_id }} {
      min-height: {{ block.settings.box_height_mobile }}px;
      padding: {{ block.settings.content_padding_mobile }}px;
    }

    .ai-split-grid__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-split-grid__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }

    .ai-split-grid__buttons-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: stretch;
    }

    .ai-split-grid__button-{{ ai_gen_id }} {
      text-align: center;
    }
  }
{% endstyle %}

